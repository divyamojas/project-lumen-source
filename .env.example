SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_backend_key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# Direct Postgres connection for migrations and raw SQL execution
# Find under Supabase dashboard → Settings → Database → Connection string (URI)
# Note: URL-encode special chars in password (e.g. @ → %40)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# On first startup with an empty user_roles table, this user will be seeded as superuser.
# Get your user ID from Supabase → Authentication → Users after creating your account.
# Remove or leave blank after bootstrap is complete.
BOOTSTRAP_SUPERUSER_ID=

# Additional CORS origins beyond the defaults (localhost:3000, https://localhost).
# Comma-separated. Example: CORS_ORIGINS=https://192.168.1.100,https://mylan.local
# CORS_ORIGINS=

# Phase 2 — S3 sync (set S3_SYNC_ENABLED=true to activate)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
S3_SYNC_ENABLED=false

# Dangerous superuser capabilities are disabled by default.
# Set to true only for trusted internal environments.
ENABLE_ADMIN_SQL=false
ENABLE_GENERIC_DATA_ADMIN=false

# Optional legacy/self-hosted compatibility:
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
# SUPABASE_ANON_KEY=your-legacy-anon-key
# SUPABASE_JWT_SECRET=your-legacy-jwt-secret
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
